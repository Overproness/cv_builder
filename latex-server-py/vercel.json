{
    "buildCommand": "bash build.sh",
    "functions": {
        "api/index.py": {
            "runtime": "@vercel/python",
            "maxDuration": 60,
            "includeFiles": "bin/tectonic"
        }
    },
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/api/index"
        }
    ]
}